{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StorageView",
  "version": "0.8.0",
  "identifier": "com.lemolek.storageview",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StorageView — Analyze. Visualize. Optimize.",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDRDdGNzEwOEYzQkZFN0UKUldSKy9qdVBFUGZYZkYrQkFXeldIWHUzYktoN2ErTHNGM0RmdXRXZGhwQXJITFFIanp1OC8xTW0K",
      "endpoints": [
        "https://github.com/Lemolek/StorageView/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Lemolek",
    "copyright": "Copyright (c) 2026 Lemolek. All rights reserved.",
    "shortDescription": "Analyze. Visualize. Optimize.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
